# Copy to .env and fill in. Load with: set -a; source .env; set +a
GARDEN_FIREBASE_KEY=serviceAccountKey.json
GARDEN_DB_URL=https://YOUR-PROJECT-default-rtdb.firebaseio.com
GARDEN_STORAGE_BUCKET=YOUR-PROJECT.appspot.com
GARDEN_ID=garden1
# Set to 1 to run without real hardware (laptop testing)
GARDEN_MOCK=0
